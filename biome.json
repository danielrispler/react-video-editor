{
	"$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": true,
		"ignore": [
			"**/node_modules",
			"**/dist",
			"**/build",
			"**/coverage",
			"**/*.tsbuildinfo"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"organizeImports": {
		"enabled": true
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"correctness": {
				"noUnusedVariables": "error",
				"useExhaustiveDependencies": "error"
			},
			"suspicious": {
				"noExplicitAny": "error",
				"noArrayIndexKey": "error",
				"noImplicitAnyLet": "error"
			},
			"style": {
				"useImportType": "error"
			},
			"security": {
				"noDangerouslySetInnerHtml": "error"
			},
			"performance": {
				"noAccumulatingSpread": "error"
			}
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		}
	},
	"overrides": [
		{
			"include": [
				"apps/frontend/src/features/editor/**",
				"src/features/editor/**",
				"apps/frontend/src/components/**",
				"src/components/**",
				"apps/frontend/src/lib/**",
				"src/lib/**",
				"apps/frontend/src/hooks/**",
				"src/hooks/**"
			],
			"linter": {
				"rules": {
					"a11y": {
						"useMediaCaption": "off",
						"useKeyWithClickEvents": "off",
						"noSvgWithoutTitle": "off"
					},
					"complexity": {
						"noBannedTypes": "off",
						"noForEach": "off"
					},
					"correctness": {
						"noUnsafeOptionalChaining": "off",
						"useExhaustiveDependencies": "off",
						"noUnusedVariables": "off"
					},
					"performance": {
						"noAccumulatingSpread": "off"
					},
					"security": {
						"noDangerouslySetInnerHtml": "off"
					},
					"style": {
						"noNonNullAssertion": "off"
					},
					"suspicious": {
						"noExplicitAny": "off",
						"noArrayIndexKey": "off",
						"noAssignInExpressions": "off",
						"noImplicitAnyLet": "off"
					}
				}
			}
		},
		{
			"include": ["apps/server/src/config/env.ts", "src/config/env.ts"],
			"linter": {
				"rules": {
					"style": {
						"useNamingConvention": "off"
					}
				}
			}
		},
		{
			"include": [
				"apps/frontend/src/features/editor/scene/droppable.tsx",
				"src/features/editor/scene/droppable.tsx"
			],
			"linter": {
				"rules": {
					"a11y": {
						"useSemanticElements": "off"
					}
				}
			}
		},
		{
			"include": [
				"apps/frontend/src/features/editor/timeline/timeline.tsx",
				"src/features/editor/timeline/timeline.tsx"
			],
			"linter": {
				"rules": {
					"a11y": {
						"useKeyWithMouseEvents": "off"
					}
				}
			}
		}
	]
}